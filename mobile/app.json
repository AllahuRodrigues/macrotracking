{
  "expo": {
    "name": "MacroTrack",
    "slug": "macrotrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "macrotrack",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0b0f0e",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rodrigues.macrotrack",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rodrigues.macrotrack",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0b0f0e"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MacroTrack needs access to your photos to log progress pictures.",
          "cameraPermission": "MacroTrack needs your camera to take progress pictures."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://macrotracking-coral.vercel.app",
      "supabaseUrl": "https://zttwerdfabsibnyezlfi.supabase.co",
      "router": {},
      "eas": {
        "projectId": "9272c6a5-4c47-4ed9-84b1-6ab12ce07cff"
      }
    },
    "owner": "allahurodrigues",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9272c6a5-4c47-4ed9-84b1-6ab12ce07cff"
    }
  }
}
